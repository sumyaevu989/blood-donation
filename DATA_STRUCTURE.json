  "eligibilityCriteria": {
    "minimumAge": 18,
    "maximumAge": 65,
    "minimumWeight": "50 kg (110 lbs)",
    "normalBloodPressure": "Required",
    "minimumHemoglobin": "12.5 g/dL",
    "timeBetweenDonations": "3-4 months",
    "healthRequirements": [
      "Good physical health",
      "Good mental health",
      "No contagious diseases",
      "No recent surgery",
      "Not pregnant"
    ]
  },

  "apiEndpoints": {
    "note": "Using LocalStorage - no backend required",
    "functions": {
      "login": "bloodDonationApp.login(id, password, phone)",
      "register": "bloodDonationApp.register(name, id, email, phone, bloodGroup, password)",
      "getAllUsers": "bloodDonationApp.getAllUsers()",
      "searchDonorsByBloodGroup": "bloodDonationApp.searchDonorsByBloodGroup(bloodGroup)",
      "searchDonorsByName": "bloodDonationApp.searchDonorsByName(name)",
      "getBloodGroupStats": "bloodDonationApp.getBloodGroupStats()",
      "saveContactMessage": "bloodDonationApp.saveContactMessage(name, email, phone, subject, bloodGroup, message)",
      "getAllContactMessages": "bloodDonationApp.getAllContactMessages()",
      "getTotalDonors": "bloodDonationApp.getTotalDonors()",
      "getDonationStats": "bloodDonationApp.getDonationStats()",
      "backupData": "bloodDonationApp.backupData()",
      "restoreData": "bloodDonationApp.restoreData(backupData)",
      "showAllData": "bloodDonationApp.showAllData()"
    }
  },

  "localStorageKeys": {
    "bloodDonationUsers": "Array of all registered users",
    "currentUser": "Currently logged-in user details",
    "contactMessages": "All contact form messages",
    "emergencyAlerts": "Active emergency alerts"
  },

