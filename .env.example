# Copy this file to `.env` and fill values for production
# Do NOT commit your real .env to version control.

# SECRET_KEY (use a long random string in production)
SECRET_KEY=django-insecure-replace-this-with-a-real-secret

# DEBUG (True or False)
DEBUG=False

# Comma separated allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,.your-vercel-domain.vercel.app

# If using a hosted DB, set a DATABASE_URL (e.g. postgres://USER:PASS@host:port/dbname)
# DATABASE_URL=postgres://user:pass@host:5432/dbname
